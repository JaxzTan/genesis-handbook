# Public Discord invite shown on the CTA + contributor wall
NEXT_PUBLIC_DISCORD_INVITE=

# Contributor wall ("Add yours →") + GitHub avatar source.
# CONTRIBUTE_URL defaults to https://github.com/<owner>/<repo> if unset.
NEXT_PUBLIC_CONTRIBUTE_URL=
NEXT_PUBLIC_GITHUB_OWNER=
NEXT_PUBLIC_GITHUB_REPO=
# Optional: raises GitHub API limit from 60/hr to 5000/hr for the wall fetch.
GITHUB_TOKEN=

# Dev server host/port (optional)
HOSTNAME=
PORT=

# Prisma / Supabase Postgres.
# DATABASE_URL: pooled connection (Supabase port 6543) used at runtime.
# DIRECT_URL: session connection (Supabase port 5432) used by the Prisma CLI
# for migrations — the transaction pooler can't hold the advisory lock.
DATABASE_URL=
DIRECT_URL=

# Secret for the hourly contributor sync cron (/api/cron/sync-contributors).
# Vercel Cron sends it as `Authorization: Bearer <CRON_SECRET>`. Set in Vercel.
CRON_SECRET=
